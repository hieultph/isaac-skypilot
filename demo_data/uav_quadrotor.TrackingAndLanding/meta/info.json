        "video.fps": 30.0,
        "video.codec": "h264",
        "video.pix_fmt": "yuv420p",
        "video.is_depth_map": false,
        "has_audio": false
      }
    },
    "observation.images.downward_camera": {
      "dtype": "video",
      "shape": [256, 256, 3],
